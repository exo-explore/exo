{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "enabledManagers": ["regex"],
  "regexManagers": [
    {
      "description": "Pin HuggingFace model revisions to commit SHAs",
      "fileMatch": [
        "^resources/inference_model_cards/.*\\.toml$",
        "^resources/image_model_cards/.*\\.toml$"
      ],
      "matchStrings": [
        "model_id = \"(?<packageName>[^\"]+)\"(?:\\n|\\r\\n?)revision = \"(?<currentDigest>[a-f0-9]{40}|main)\""
      ],
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "https://huggingface.co/{{packageName}}",
      "packageNameTemplate": "https://huggingface.co/{{packageName}}",
      "currentValueTemplate": "main",
      "versioningTemplate": "git"
    }
  ],
  "packageRules": [
    {
      "description": "Update model revisions to latest commit",
      "matchDatasources": ["git-refs"],
      "matchPackageNames": ["https://huggingface.co/**"],
      "groupName": null,
      "automerge": false,
      "commitMessageTopic": "{{depName}} revision",
      "commitMessageExtra": "from {{currentDigest}} to {{newDigest}}"
    }
  ]
}
